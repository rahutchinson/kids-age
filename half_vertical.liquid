{% assign name = trmnl:plugin_settings:custom_fields_values:name_1 | default: 'Child' %}
{% assign dob = trmnl:plugin_settings:custom_fields_values:dob_1 | default: '2020-01-01' %}
{% assign timezone = trmnl:plugin_settings:custom_fields_values:time_zone | default: 'UTC' %}

{% assign today_str = 'now' | date: '%Y-%m-%d %H:%M:%S' | date: '%s' | timezone: timezone | date: '%Y-%m-%d' %}

{% assign today_s = today_str | date: '%s' | plus: 0 %}
{% assign dob_s = dob | date: '%s' | plus: 0 %}
{% assign diff_s = today_s | minus: dob_s %}
{% assign total_days = diff_s | divided_by: 86400 %}

{% assign today_year  = today_str | date: '%Y' | plus: 0 %}
{% assign today_month = today_str | date: '%m' | plus: 0 %}
{% assign today_day   = today_str | date: '%d' | plus: 0 %}
{% assign dob_year  = dob | date: '%Y' | plus: 0 %}
{% assign dob_month = dob | date: '%m' | plus: 0 %}
{% assign dob_day   = dob | date: '%d' | plus: 0 %}

{% assign years  = today_year  | minus: dob_year %}
{% assign months = today_month | minus: dob_month %}
{% assign days   = today_day   | minus: dob_day %}

{% if days < 0 %}
  {% assign months = months | minus: 1 %}
  {% assign prev_month = today_month | minus: 1 %}
  {% if prev_month == 0 %}{% assign prev_month = 12 %}{% endif %}
  {% if prev_month == 2 %}
    {% assign lc4   = today_year | modulo: 4 %}
    {% assign lc100 = today_year | modulo: 100 %}
    {% assign lc400 = today_year | modulo: 400 %}
    {% assign feb_days = 28 %}
    {% if lc4 == 0 %}
      {% if lc100 != 0 %}
        {% assign feb_days = 29 %}
      {% elsif lc400 == 0 %}
        {% assign feb_days = 29 %}
      {% endif %}
    {% endif %}
    {% assign days = days | plus: feb_days %}
  {% elsif prev_month == 4 or prev_month == 6 or prev_month == 9 or prev_month == 11 %}
    {% assign days = days | plus: 30 %}
  {% else %}
    {% assign days = days | plus: 31 %}
  {% endif %}
{% endif %}

{% if months < 0 %}
  {% assign years  = years  | minus: 1 %}
  {% assign months = months | plus: 12 %}
{% endif %}

{% if years > 0 %}
  {% assign primary_value = years %}
  {% if years == 1 %}
    {% assign primary_unit = 'year old' %}
  {% else %}
    {% assign primary_unit = 'years old' %}
  {% endif %}
  {% assign secondary = months | append: ' mo · ' | append: days | append: ' d' %}
{% elsif months > 0 %}
  {% assign primary_value = months %}
  {% if months == 1 %}
    {% assign primary_unit = 'month old' %}
  {% else %}
    {% assign primary_unit = 'months old' %}
  {% endif %}
  {% assign secondary = days | append: ' days' %}
{% else %}
  {% assign primary_value = total_days %}
  {% if total_days == 1 %}
    {% assign primary_unit = 'day old' %}
  {% else %}
    {% assign primary_unit = 'days old' %}
  {% endif %}
  {% assign secondary = '' %}
{% endif %}

<div class="view">
  <div class="layout layout--col layout--center gap--medium">
    <span class="value value--large">{{ name }}</span>
    <span class="value value--xxxlarge">{{ primary_value }}</span>
    <span class="label">{{ primary_unit }}</span>
    {% if secondary != '' %}
      <span class="label">{{ secondary }}</span>
    {% endif %}
  </div>
</div>

<div class="title_bar">
  <span class="title">Kids' Ages</span>
  <span class="instance">{{ name }}</span>
</div>
